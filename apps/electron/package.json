{
	"name": "@imperium/electron",
	"version": "0.1.0",
	"private": true,
	"description": "Imperium OS Desktop App",
	"author": "Imperium Team",
	"type": "module",
	"main": "dist/main/index.js",
	"scripts": {
		"dev": "concurrently -k --names VITE,ELECTRON -c cyan,magenta \"bun run dev:renderer\" \"bun run dev:electron\"",
		"dev:renderer": "vite --strictPort",
		"dev:electron": "bun run build:main && bun run build:preload && bunx electron .",
		"start": "ELECTRON_USE_LOCAL_RENDERER=1 bun run build && electron .",
		"build:renderer": "vite build",
		"build": "bun run build:renderer && bun run build:preload && bun run build:main",
		"build:main": "bunx esbuild src/main/index.ts --bundle --outfile=dist/main/index.js --external:electron --external:better-sqlite3 --external:bun:sqlite --format=esm --platform=node",
		"build:preload": "bunx esbuild src/preload/index.ts --bundle --outfile=dist/preload/index.js --external:electron --format=cjs",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check ./src",
		"clean": "rm -rf dist out release",
		"electron:dev": "bun run build:main && bun run build:preload && electron .",
		"electron:build": "bun run build && electron-builder"
	},
	"build": {
		"appId": "com.imperium.master",
		"productName": "Imperium",
		"directories": {
			"buildResources": "build",
			"output": "release"
		},
		"files": [
			"dist/**",
			"!dist/**/*.map"
		],
		"mac": {
			"category": "public.app-category.developer-tools",
			"target": [
				{
					"target": "dmg",
					"arch": [
						"arm64",
						"x64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"arm64",
						"x64"
					]
				}
			]
		},
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			]
		},
		"linux": {
			"target": [
				{
					"target": "AppImage",
					"arch": [
						"x64"
					]
				},
				{
					"target": "deb",
					"arch": [
						"x64"
					]
				}
			],
			"category": "Development"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		}
	},
	"dependencies": {
		"@imperium/core-notifications": "workspace:*",
		"@imperium/shared-types": "workspace:*",
		"@imperium/ui-shared": "workspace:*",
		"better-sqlite3": "^12.6.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.3",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.1.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.0",
		"autoprefixer": "^10.4.0",
		"concurrently": "^9.2.1",
		"electron": "33.0.0",
		"electron-builder": "^25.1.0",
		"jsdom": "^25.0.0",
		"postcss": "^8.4.0",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^2.1.0",
		"wait-on": "^8.0.3"
	}
}
