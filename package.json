{
  "name": "@imperium/root",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/core/*",
    "packages/mcp-internal/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "turbo": "^2.4.0",
    "prettier": "^3.4.0",
    "@biomejs/biome": "^1.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.2.0"
}
