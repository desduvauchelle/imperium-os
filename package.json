{
	"name": "@imperium/root",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"packages/core/*",
		"packages/mcp-internal/*",
		"apps/*"
	],
	"scripts": {
		"dev": "cd apps/electron && bun run dev",
		"desktop:dev": "cd apps/electron && bun run dev",
		"start": "bun install && cd apps/electron && bun run start",
		"desktop": "cd apps/electron && bun run start",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"lint": "turbo lint",
		"format": "prettier --write .",
		"clean": "turbo clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"bun-types": "^1.3.10",
		"prettier": "^3.4.0",
		"turbo": "^2.4.0",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "bun@1.2.0"
}
