    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@imperium/shared-types": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.38.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
